{
  "overwrite": true,
  "title": "eBPF Blockchain - Health Overview",
  "uid": "ebpf-health-overview",
  "description": "Dashboard unificado de salud del sistema eBPF Blockchain",
  "tags": [
    "ebpf",
    "health",
    "overview"
  ],
  "timezone": "browser",
  "schemaVersion": 30,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Resumen del Sistema",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "title": "Uptime del Nodo",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "expr": "ebpf_node_uptime_seconds",
          "legendFormat": "uptime",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 3600
              },
              {
                "color": "red",
                "value": 86400
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Peers Conectados",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "targets": [
        {
          "expr": "ebpf_node_peers_connected{status=\"connected\"}",
          "legendFormat": "peers",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "green",
                "value": 10
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Transacciones Confirmadas",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "expr": "ebpf_node_transactions_confirmed_total",
          "legendFormat": "confirmed",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Bloques Propuestos",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "targets": [
        {
          "expr": "ebpf_node_blocks_proposed_total",
          "legendFormat": "blocks",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Red P2P - Tráfico de Mensajes",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "expr": "rate(ebpf_node_messages_sent_total[5m])",
          "legendFormat": "Enviados/s",
          "refId": "A"
        },
        {
          "expr": "rate(ebpf_node_messages_received_total[5m])",
          "legendFormat": "Recibidos/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Peers por Estado",
      "type": "piechart",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 5
      },
      "targets": [
        {
          "expr": "ebpf_node_peers_connected",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Ancho de Banda",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 5
      },
      "targets": [
        {
          "expr": "rate(ebpf_node_bandwidth_sent_bytes_total[5m])",
          "legendFormat": "Enviado",
          "refId": "A"
        },
        {
          "expr": "rate(ebpf_node_bandwidth_received_bytes_total[5m])",
          "legendFormat": "Recibido",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      }
    },
    {
      "id": 9,
      "title": "Consenso - Rendimiento",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "targets": [
        {
          "expr": "ebpf_node_consensus_duration_ms",
          "legendFormat": "Duración (ms)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "id": 10,
      "title": "Transacciones Procesadas",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "targets": [
        {
          "expr": "rate(ebpf_node_transactions_processed_total[5m])",
          "legendFormat": "TPS",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "id": 11,
      "title": "Seguridad - Alertas",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 21
      }
    },
    {
      "id": 12,
      "title": "Intentos Sybil Detectados",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 22
      },
      "targets": [
        {
          "expr": "ebpf_node_sybil_attempts_total",
          "legendFormat": "sybil",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      }
    },
    {
      "id": 13,
      "title": "Replay Attacks Rechazados",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 22
      },
      "targets": [
        {
          "expr": "ebpf_node_transactions_replay_rejected_total",
          "legendFormat": "replay",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        }
      }
    },
    {
      "id": 14,
      "title": "XDP Packets Dropped",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 22
      },
      "targets": [
        {
          "expr": "ebpf_node_xdp_packets_dropped_total",
          "legendFormat": "dropped",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 100
              },
              {
                "color": "red",
                "value": 1000
              }
            ]
          }
        }
      }
    },
    {
      "id": 15,
      "title": "Tamaño Whitelist/Blacklist",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 22
      },
      "targets": [
        {
          "expr": "ebpf_node_xdp_whitelist_size",
          "legendFormat": "whitelist",
          "refId": "A"
        },
        {
          "expr": "ebpf_node_xdp_blacklist_size",
          "legendFormat": "blacklist",
          "refId": "B"
        }
      ]
    }
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  }
}