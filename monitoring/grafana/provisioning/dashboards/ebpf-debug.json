{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Global Cluster Status",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 101,
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "name" },
      "targets": [
        { "expr": "up{job=~\"ebpf-node-.*\"}", "legendFormat": "{{instance}}", "refId": "A" }
      ],
      "title": "Nodes Online",
      "type": "stat",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "dark-red", "value": null },
              { "color": "dark-green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 102,
      "options": { "colorMode": "value", "graphMode": "area" },
      "targets": [
        { "expr": "sum(ebpf_node_peers_connected{instance=~\"$node\"}) by (instance)", "legendFormat": "{{instance}}", "refId": "A" }
      ],
      "title": "Peers Connected",
      "type": "stat",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "orange", "value": null },
              { "color": "blue", "value": 2 }
            ]
          }
        }
      }
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 103,
      "options": { "colorMode": "value" },
      "targets": [
        { "expr": "sum(rate(ebpf_node_messages_received_total{instance=~\"$node\"}[1m])) by (instance)", "legendFormat": "{{instance}}", "refId": "A" }
      ],
      "title": "Gossip MPS",
      "type": "stat",
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "color": { "fixedColor": "cyan", "mode": "fixed" }
        }
      }
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 1 },
      "id": 104,
      "options": { "colorMode": "value", "justifyMode": "center" },
      "targets": [
        { "expr": "sum(ebpf_node_gossip_packets_trace_total{instance=~\"$node\"})", "refId": "A" }
      ],
      "title": "Global Data Ingested (Packets)",
      "type": "stat",
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "purple", "mode": "fixed" }
        }
      }
    },
    {
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 200,
      "title": "Transaction Ledger & Consensus (Loki)",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "Loki" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "id": 201,
      "options": {
        "showHeader": true
      },
      "targets": [
        { "expr": "{job=~\"ebpf-node-.*\"} | json | event=\"rpc_tx_received\" | line_format \"{{.tx_id}} | {{.data}}\"", "format": "table", "refId": "A" }
      ],
      "title": "Mempool Ingest (RPC)",
      "type": "table"
    },
    {
      "datasource": { "type": "loki", "uid": "Loki" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "id": 202,
      "options": {
        "showHeader": true
      },
      "targets": [
        { "expr": "{job=~\"ebpf-node-.*\"} | json | event=\"gossip_tx_proposal\" | line_format \"{{.tx_id}} | from {{.sender}}\"", "format": "table", "refId": "A" }
      ],
      "title": "Propagation Stream (Gossip)",
      "type": "table"
    },
    {
      "datasource": { "type": "loki", "uid": "Loki" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "id": 203,
      "options": {
        "showHeader": true
      },
      "targets": [
        { "expr": "{job=~\"ebpf-node-.*\"} | json | event=\"gossip_vote_received\" | line_format \"{{.tx_id}} | Voted by {{.voter}}\"", "format": "table", "refId": "A" }
      ],
      "title": "Consensus Approvals (Votes)",
      "type": "table"
    },
    {
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 300,
      "title": "eBPF Kernel Insight (Latency Distribution)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 15 },
      "id": 301,
      "options": {
        "calculate": { "toggle": false },
        "cellGap": 1,
        "color": { "mode": "scheme", "scheme": "Oranges" },
        "exemplars": { "color": "rgba(255,0,255,1)" },
        "tooltip": { "show": true }
      },
      "targets": [
        { "expr": "ebpf_node_latency_buckets{instance=~\"$node\"}", "legendFormat": "{{bucket}}", "refId": "A" }
      ],
      "title": "eBPF Kernel Latency Heatmap",
      "type": "heatmap"
    },
    {
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 400,
      "title": "System Logs (All Events)",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "Loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 26 },
      "id": 401,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        { "expr": "{job=~\"ebpf-node-.*\"}", "refId": "A" }
      ],
      "title": "Node Event Stream (JSON Debug)",
      "type": "logs"
    }
  ],
  "refresh": "2s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["ebpf", "p2p", "cluster", "observability", "loki"],
  "templating": {
    "list": [
      {
        "current": { "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(up{job=~\"ebpf-node-.*\"}, instance)",
        "hide": 0,
        "includeAll": true,
        "label": "Node",
        "multi": true,
        "name": "node",
        "query": { "query": "label_values(up{job=~\"ebpf-node-.*\"}, instance)", "refId": "PrometheusVariableQuery" },
        "refresh": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": { "refresh_intervals": ["1s", "2s", "5s", "10s"] },
  "timezone": "browser",
  "title": "eBPF P2P Debug",
  "uid": "ebpf-debug",
  "version": 4
}
